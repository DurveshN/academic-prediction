# Database Configuration
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=academic_db
DATABASE_URL=postgresql+asyncpg://dbadmin:your-rds-password@your-rds-endpoint:5432/postgres

# JWT Authentication
JWT_SECRET_KEY=generate-a-secure-random-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=backend/mlruns

# AWS (optional - for S3 artifact storage)
AWS_S3_BUCKET=your-app-name-mlflow-artifacts

# Environment
ENVIRONMENT=production

# Frontend
FRONTEND_URL=https://yourdomain.com
