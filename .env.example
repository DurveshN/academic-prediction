# Database Configuration
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=academic_db
DATABASE_URL=postgresql://appuser:changeme-strong-password@db:5432/academic_db

# JWT Authentication
JWT_SECRET_KEY=generate-a-secure-random-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Environment
ENVIRONMENT=local
